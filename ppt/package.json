{
  "name": "html-ppt-agent-skill",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Project generation, validation, bundling, screenshot, PDF, and regression-example tools for the HTML PPT agent skill.",
  "scripts": {
    "create": "node scripts/create-deck.mjs",
    "bundle": "node scripts/bundle-html.mjs",
    "validate": "node scripts/validate-deck.mjs",
    "qa": "node scripts/qa-deck.mjs",
    "pdf": "node scripts/export-pdf.mjs",
    "example:validate": "node scripts/validate-deck.mjs examples/ai-ad-workflow/index.html",
    "example:bundle": "node scripts/bundle-html.mjs examples/ai-ad-workflow/index.html examples/ai-ad-workflow/dist/ai-ad-workflow.html",
    "example:qa": "node scripts/qa-deck.mjs examples/ai-ad-workflow/index.html --screenshots examples/ai-ad-workflow/qa/screenshots"
  },
  "devDependencies": {
    "playwright": "^1.55.0"
  },
  "engines": {
    "node": ">=20"
  }
}
