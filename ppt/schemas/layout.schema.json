{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yaney01/skill/blob/main/ppt/schemas/layout.schema.json",
  "title": "HTML PPT theme layout manifest",
  "type": "object",
  "required": ["manifestVersion", "theme", "tier", "stage", "contracts", "layouts"],
  "properties": {
    "manifestVersion": {"const": 1},
    "theme": {"type": "string", "minLength": 1},
    "tier": {"enum": ["core", "backup"]},
    "stage": {"const": "1920x1080"},
    "contracts": {"type": "string", "minLength": 1},
    "legacyAliases": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "layouts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "selector"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "selector": {"type": "string", "minLength": 2},
          "variants": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
