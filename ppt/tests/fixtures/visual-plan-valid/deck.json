    },
    {
      "id": "slide-02",
      "purpose": "explain",
      "layout": "process",
      "headline": "三步生产链",
      "visual": { "type": "workflow-diagram", "required": true, "status": "ready", "source": "html", "role": "explanation", "slot": "16:9" }
    },
    {
      "id": "slide-03",
      "purpose": "reset",
      "layout": "statement",
      "headline": "没有视觉决策，就没有视觉叙事。",
      "visual": { "type": "intentional-text", "required": false, "status": "ready", "source": "css", "role": "typography" }
    },
    {
      "id": "slide-04",
      "purpose": "compare",
      "layout": "comparison",
      "headline": "机械正确与视觉完整",
      "visual": { "type": "comparison-diagram", "required": true, "status": "ready", "source": "html", "role": "comparison", "slot": "16:9" }
    }
  ]
