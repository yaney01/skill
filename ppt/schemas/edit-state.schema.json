{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yaney01.github.io/skill/ppt/schemas/edit-state.schema.json",
  "title": "HTML PPT browser edit state",
  "type": "object",
  "required": ["version", "deckId", "updatedAt", "elements"],
  "properties": {
    "version": { "const": 2 },
    "deckId": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "elements": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/textEdit" },
          { "$ref": "#/$defs/imageEdit" }
        ]
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "textEdit": {
      "type": "object",
      "required": ["type", "html"],
      "properties": {
        "type": { "const": "text" },
        "html": { "type": "string" }
      },
      "additionalProperties": false
    },
    "imageEdit": {
      "type": "object",
      "required": ["type", "src", "alt", "fit", "focus"],
      "properties": {
        "type": { "const": "image" },
        "src": { "type": "string" },
        "alt": { "type": "string" },
        "fit": { "enum": ["", "cover", "contain"] },
        "focus": { "type": "string", "maxLength": 64 }
      },
      "additionalProperties": false
    }
  }
}
