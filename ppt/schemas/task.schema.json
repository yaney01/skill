{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yaney01/skill/ppt/schemas/task.schema.json",
  "title": "HTML PPT task regression cases",
  "type": "object",
  "required": ["manifestVersion", "cases"],
  "properties": {
    "manifestVersion": {"const": 1},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/taskCase"}
    }
  },
  "$defs": {
    "taskCase": {
      "type": "object",
      "required": ["id", "title", "language", "density", "theme", "visualStrategy", "slides", "expected"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "title": {"type": "string", "minLength": 1},
        "language": {"type": "string", "minLength": 2},
        "density": {"enum": ["speaker-led", "reading-first"]},
        "theme": {"type": "string", "minLength": 1},
        "source": {
          "type": "object",
          "required": ["fixture", "mode", "strict"],
          "properties": {
            "fixture": {"type": "string", "minLength": 1},
            "mode": {"enum": ["semantic", "preserve-layout"]},
            "strict": {"type": "boolean"},
            "expectedWarnings": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "visualStrategy": {"type": "object"},
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["layout", "headline", "visual"],
            "properties": {
              "layout": {"type": "string", "minLength": 1},
              "headline": {"type": "string", "minLength": 1},
              "body": {"type": "string"},
              "assetPath": {"type": "string"},
              "visual": {"type": "object"}
            },
            "additionalProperties": false
          }
        },
        "sourceMapping": {"type": "array"},
        "expected": {
          "type": "object",
          "required": ["slideCount", "uniqueLayoutsMin", "requiredLayouts", "sourceCoverage", "offline", "bundle", "contactSheet"],
          "properties": {
            "slideCount": {"type": "integer", "minimum": 1},
            "uniqueLayoutsMin": {"type": "integer", "minimum": 1},
            "requiredLayouts": {"type": "array", "items": {"type": "string"}},
            "sourceCoverage": {"type": "boolean"},
            "preserveSourceOneToOne": {"type": "boolean"},
            "offline": {"type": "boolean"},
            "bundle": {"type": "boolean"},
            "contactSheet": {"type": "boolean"},
            "longTitleRequired": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
