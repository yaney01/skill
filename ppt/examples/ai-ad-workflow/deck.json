      "purpose": "key-claim",
      "layout": "statement",
      "headline": "效率问题，不是生成得不够快，而是决策链仍然是手工的。",
      "notes": { "speaker": "这里停顿一下。生成速度已经提升，但需求解释、审核和返工仍然串行。", "durationSeconds": 45, "private": true },
      "visual": { "type": "intentional-text", "required": false, "status": "ready", "source": "css", "role": "typography" }
