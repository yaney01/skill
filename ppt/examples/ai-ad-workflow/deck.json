    },
    {
      "id": "slide-11",
      "purpose": "plan",
      "layout": "timeline",
      "headline": "用四个阶段建立团队级工作流",
      "notes": { "speaker": "不要一次重做全部流程，从一个高频、规则明确的场景开始。", "durationSeconds": 70, "private": true },
      "visual": { "type": "timeline", "required": true, "status": "ready", "source": "html", "role": "explanation" }
    },
    {
      "id": "slide-12",
      "purpose": "close",
      "layout": "closing",
      "headline": "从一次成功，走向可复用的系统。",
      "notes": { "speaker": "收束到四项行动，并提出选择一个试点任务作为下一步。", "durationSeconds": 45, "private": true },
      "visual": { "type": "typographic", "required": false, "status": "ready", "source": "css", "role": "typography" }
