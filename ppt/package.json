{
  "name": "html-ppt-agent-skill",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Project generation, validation, bundling, browser QA, PDF export, examples, and automated tests for the HTML PPT agent skill.",
  "scripts": {
    "create": "node scripts/create-deck.mjs",
    "bundle": "node scripts/bundle-html.mjs",
    "validate": "node scripts/validate-deck.mjs",
    "qa": "node scripts/qa-deck.mjs",
    "pdf": "node scripts/export-pdf.mjs",
    "test:core": "node --test tests/structure.test.mjs tests/bundle.test.mjs",
    "test:browser": "node --test --test-concurrency=1 tests/runtime.test.mjs tests/editor.test.mjs",
    "test": "npm run test:core && npm run test:browser",
    "ci": "npm run test && npm run example:validate && npm run example:bundle && node scripts/validate-deck.mjs examples/ai-ad-workflow/dist/ai-ad-workflow.html",
    "example:validate": "node scripts/validate-deck.mjs examples/ai-ad-workflow/index.html",
    "example:bundle": "node scripts/bundle-html.mjs examples/ai-ad-workflow/index.html examples/ai-ad-workflow/dist/ai-ad-workflow.html",
    "example:qa": "node scripts/qa-deck.mjs examples/ai-ad-workflow/index.html --screenshots examples/ai-ad-workflow/qa/screenshots"
  },
  "devDependencies": {
    "playwright": "^1.55.0"
  },
  "engines": {
    "node": ">=20"
  }
}
